# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Work / Primary IMAP
WORK_IMAP_HOST=imap.yourworkdomain.com
WORK_IMAP_EMAIL=your_email@yourworkdomain.com
WORK_IMAP_PASSWORD=your_app_password

# Personal / Secondary IMAP
PERSONAL_IMAP_HOST=imap.yourpersonaldomain.com
PERSONAL_IMAP_EMAIL=your_email@yourpersonaldomain.com
PERSONAL_IMAP_USERNAME=your_username_if_different_from_email
PERSONAL_IMAP_PASSWORD=your_app_password

# Persona for AI Drafting
MY_PERSONA="I am a software engineer. My tone is concise, professional, and friendly. I usually sign off with 'Best, [My Name]'"
